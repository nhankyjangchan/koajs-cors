{
    "name": "@nhankyjangchan/koa-cors",
    "version": "1.4.2",
    "private": false,
    "description": "Cross-Origin Resource Sharing (CORS) middleware for KoaJS written in TypeScript",
    "keywords": [
        "cors",
        "middleware",
        "http",
        "Cross-Origin Resource Sharing",
        "koa-cors",
        "koajs-cors",
        "koa/cors",
        "koa",
        "koajs",
        "@nhankyjangchan/koajs-cors"
    ],
    "homepage": "https://github.com/nhankyjangchan/koa-cors",
    "license": "MIT",
    "type": "module",
    "types": "./dist/index.d.ts",
    "module": "./dist/index.mjs",
    "main": "./dist/index.cjs",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "CHANGELOG.md",
        "LICENSE",
        "README.md",
        "package.json"
    ],
    "author": {
        "name": "Timur Schuchkin \"Nhankyjangchan\"",
        "email": "dev.schuchkin.timur@gmail.com",
        "url": "https://github.com/nhankyjangchan"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nhankyjangchan/koa-cors.git"
    },
    "bugs": {
        "url": "https://github.com/nhankyjangchan/koa-cors/issues",
        "email": "dev.schuchkin.timur@gmail.com"
    },
    "scripts": {
        "build": "bun run build:cjs && bun run build:esm && bun run build:types",
        "build:cjs": "bun build ./src/index.ts --outfile ./dist/index.cjs --target node --format cjs --minify --external '*'",
        "build:esm": "bun build ./src/index.ts --outfile ./dist/index.mjs --target node --format esm --minify --external '*'",
        "build:types": "tsc --emitDeclarationOnly --outDir ./dist",
        "p:write": "bunx prettier . --write"
    },
    "engines": {
        "bun": ">= 1.3",
        "node": ">= 20",
        "npm": ">= 8"
    },
    "os": [
        "darwin",
        "linux",
        "win32",
        "aix",
        "freebsd",
        "openbsd"
    ],
    "devDependencies": {
        "@types/http-errors": "^2.0.5",
        "@types/jest": "^30.0.0",
        "@types/koa": "^3.0.2",
        "@types/supertest": "^7.2.0",
        "@types/vary": "^1.1.3",
        "koa": "^3.2.0",
        "prettier": "^3.8.3",
        "supertest": "^7.2.2",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "vary": "^1.1.2"
    }
}
